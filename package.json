{
  "name": "myblog",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && node -e \"const f=require('fs');const j=JSON.parse(f.readFileSync('./dist/server/wrangler.json','utf8'));j.kv_namespaces=[];f.writeFileSync('./dist/server/wrangler.json',JSON.stringify(j))\"",
    "preview": "astro preview",
    "astro": "astro",
    "generate-types": "wrangler types"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.1.10",
    "@astrojs/sitemap": "^3.7.2",
    "astro": "^6.1.8",
    "wrangler": "^4.83.0"
  },
  "overrides": {
    "vite": "^7"
  }
}
