---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'シンプルでモダンな日本語ブログ' } = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a href="/" class="site-title">My Blog</a>
        <nav>
          <a href="/">記事一覧</a>
        </nav>
      </div>
    </header>

    <main class="container">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>&copy; {new Date().getFullYear()} My Blog. All rights reserved.</p>
      </div>
    </footer>
  </body>
</html>

<style>
  .site-header {
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .site-header .container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 1rem;
    padding-bottom: 1rem;
  }

  .site-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: -0.01em;
  }

  .site-title:hover {
    color: var(--color-accent);
  }

  nav a {
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  nav a:hover {
    color: var(--color-accent);
  }

  .container {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  main.container {
    padding-top: 3rem;
    padding-bottom: 4rem;
    min-height: calc(100vh - 130px);
  }

  .site-footer {
    border-top: 1px solid var(--color-border);
    padding: 1.5rem 0;
    text-align: center;
  }

  .site-footer p {
    color: var(--color-text-muted);
    font-size: 0.85rem;
  }
</style>
