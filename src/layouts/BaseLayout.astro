---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  fullWidth?: boolean;
  ogImage?: string;
  pubDate?: Date;
}

const {
  title,
  description = 'モテる男の教科書 | 自分磨き・恋愛・健康・投資',
  fullWidth = false,
  ogImage = '/hero-cafe.jpg',
  pubDate,
} = Astro.props;

const siteUrl = 'https://mote-lab.radtec38.workers.dev';
const ogImageUrl = ogImage?.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- OGP -->
    <meta property="og:type" content="article" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="モテる男の教科書" />
    <meta property="og:locale" content="ja_JP" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-RRMC43BNZL"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-RRMC43BNZL');
    </script>

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- JSON-LD Structured Data -->
    {pubDate ? (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Article",
        "headline": title,
        "description": description,
        "image": ogImageUrl,
        "datePublished": pubDate.toISOString(),
        "author": {
          "@type": "Person",
          "name": "Ken"
        },
        "publisher": {
          "@type": "Organization",
          "name": "モテる男の教科書",
          "logo": {
            "@type": "ImageObject",
            "url": `${siteUrl}/author.jpg`
          }
        },
        "mainEntityOfPage": {
          "@type": "WebPage",
          "@id": canonicalUrl
        }
      })} />
    ) : (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "モテる男の教科書",
        "url": siteUrl,
        "description": description
      })} />
    )}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&display=swap" rel="stylesheet" />
  </head>
  <body>
    <header class="site-header">
      <div class="header-inner">
        <a href="/" class="site-logo">
          <span class="logo-mark">◆</span>
          <span class="logo-text">モテる男の教科書</span>
        </a>
        <nav class="site-nav">
          <a href="/">HOME</a>
          <a href="/">ARTICLES</a>
          <a href="/about">ABOUT</a>
        </nav>
        <a href="/" class="nav-contact">CONTACT</a>
      </div>
    </header>

    <main class={fullWidth ? '' : 'page-content'}>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-logo">
          <span class="logo-mark">◆</span>
          <span class="logo-text">モテる男の教科書</span>
        </div>
        <p class="footer-copy">&copy; {new Date().getFullYear()} My Blog. All rights reserved.</p>
      </div>
    </footer>
  </body>
</html>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(10, 10, 10, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2.5rem;
    height: 72px;
  }

  .site-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-text);
    text-decoration: none;
  }

  .logo-mark {
    color: var(--color-accent);
    font-size: 1.2rem;
  }

  .logo-text {
    font-family: 'Cormorant Garamond', var(--font-serif);
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    color: var(--color-text);
  }

  .site-nav {
    display: flex;
    gap: 2.5rem;
  }

  .site-nav a {
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    color: var(--color-text-muted);
    transition: color 0.2s;
  }

  .site-nav a:hover {
    color: var(--color-text);
  }

  .nav-contact {
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    color: var(--color-text);
    border: 1px solid var(--color-border);
    padding: 0.5rem 1.25rem;
    transition: all 0.2s;
  }

  .nav-contact:hover {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: #fff;
  }

  .page-content {
    max-width: 1200px;
    margin: 0 auto;
    padding: 120px 2.5rem 6rem;
  }

  .site-footer {
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    padding: 2.5rem 0;
  }

  .footer-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .footer-copy {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    letter-spacing: 0.05em;
  }

  @media (max-width: 768px) {
    .header-inner {
      padding: 0 1.25rem;
    }
    .site-nav {
      display: none;
    }
    .nav-contact {
      display: none;
    }
  }
</style>
