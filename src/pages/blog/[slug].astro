---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import AuthorCard from '../../components/AuthorCard.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

function formatDate(date: Date): string {
  return date.toLocaleDateString('ja-JP', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
  }).replace(/\//g, '.');
}
---

<BaseLayout title={`${post.data.title} | 5000万あるのに通勤する男`} description={post.data.description} fullWidth={true} ogImage={post.data.image} pubDate={post.data.pubDate}>

  <!-- 記事バナー -->
  {post.data.image && (
    <div class="banner">
      <img src={post.data.image} alt={post.data.title} class="banner-img" />
      <div class="banner-overlay"></div>
      <div class="banner-content">
        <div class="banner-meta">
          <time>{formatDate(post.data.pubDate)}</time>
          {post.data.tags && post.data.tags[0] && (
            <span class="banner-tag">{post.data.tags[0]}</span>
          )}
        </div>
        <h1 class="banner-title">{post.data.title}</h1>
      </div>
    </div>
  )}

  <!-- 記事本文 -->
  <div class="article-wrap">
    <article class="article">
      {!post.data.image && (
        <header class="article-header-plain">
          <div class="banner-meta">
            <time>{formatDate(post.data.pubDate)}</time>
            {post.data.tags && post.data.tags[0] && (
              <span class="banner-tag">{post.data.tags[0]}</span>
            )}
          </div>
          <h1 class="plain-title">{post.data.title}</h1>
        </header>
      )}
      <p class="article-description">{post.data.description}</p>
      <div class="article-body">
        <Content />
      </div>
      <!-- 著者情報 -->
      <div class="article-author">
        <AuthorCard variant="compact" />
      </div>

      <footer class="article-footer">
        <a href="/" class="back-link">← 記事一覧に戻る</a>
      </footer>
    </article>
  </div>

</BaseLayout>

<style>
  /* バナー */
  .banner {
    position: relative;
    width: 100%;
    height: 60vh;
    min-height: 400px;
    overflow: hidden;
    margin-top: 72px;
  }

  .banner-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .banner-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.2) 60%);
  }

  .banner-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 3rem 8%;
  }

  .banner-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .banner-meta time {
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.6);
  }

  .banner-tag {
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    border: 1px solid var(--color-accent);
    padding: 0.15rem 0.6rem;
  }

  .banner-title {
    font-family: var(--font-serif);
    font-size: clamp(1.8rem, 4vw, 3rem);
    font-weight: 400;
    color: #fff;
    line-height: 1.3;
    max-width: 800px;
  }

  /* 記事本文 */
  .article-wrap {
    max-width: 800px;
    margin: 0 auto;
    padding: 4rem 2.5rem 6rem;
  }

  .article-header-plain {
    padding-top: 100px;
    margin-bottom: 2rem;
  }

  .plain-title {
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 400;
    line-height: 1.4;
    color: var(--color-text);
  }

  .article-description {
    font-size: 1rem;
    color: var(--color-text-muted);
    line-height: 1.8;
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .article-body {
    font-size: 1rem;
    line-height: 1.9;
    color: var(--color-text);
  }

  .article-body :global(h2) {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 400;
    margin: 3rem 0 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text);
  }

  .article-body :global(h3) {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 2.5rem 0 1rem;
    color: var(--color-text);
  }

  .article-body :global(p) {
    margin-bottom: 1.75rem;
    color: rgba(240,236,228,0.85);
  }

  .article-body :global(ul),
  .article-body :global(ol) {
    margin: 0 0 1.75rem 1.5rem;
  }

  .article-body :global(li) {
    margin-bottom: 0.5rem;
    color: rgba(240,236,228,0.85);
  }

  .article-body :global(strong) {
    font-weight: 700;
    color: var(--color-text);
  }

  .article-body :global(code) {
    font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace;
    font-size: 0.85em;
    background: var(--color-surface2);
    padding: 0.15em 0.45em;
    color: var(--color-accent-hover);
  }

  .article-body :global(pre) {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    color: #e2e8f0;
    padding: 1.5rem;
    overflow-x: auto;
    margin: 0 0 1.75rem;
    font-size: 0.875rem;
    line-height: 1.7;
  }

  .article-body :global(pre code) {
    background: none;
    padding: 0;
    color: inherit;
  }

  .article-body :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding: 0.5rem 0 0.5rem 1.5rem;
    margin: 0 0 1.75rem;
    color: var(--color-text-muted);
    font-style: italic;
  }

  .article-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.75rem;
    font-size: 0.9rem;
  }

  .article-body :global(th) {
    background: var(--color-surface);
    color: var(--color-text);
    padding: 0.75rem 1rem;
    text-align: left;
    font-weight: 600;
    border-bottom: 2px solid var(--color-border);
    font-size: 0.8rem;
    letter-spacing: 0.05em;
  }

  .article-body :global(td) {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--color-border);
    color: rgba(240,236,228,0.8);
  }

  .article-author {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .article-footer {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .back-link {
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    transition: color 0.2s;
  }

  .back-link:hover {
    color: var(--color-accent);
  }
</style>
