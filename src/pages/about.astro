---
import BaseLayout from '../layouts/BaseLayout.astro';
import AuthorCard from '../components/AuthorCard.astro';
---

<BaseLayout title="About | モテる男の教科書" description="モテる男の教科書の著者について">

  <div class="about-page">

    <!-- ページタイトル -->
    <header class="about-header">
      <p class="about-eyebrow">ABOUT</p>
      <h1 class="about-title">このブログについて</h1>
      <div class="about-line"></div>
    </header>

    <!-- 著者プロフィール -->
    <section class="about-section">
      <h2 class="section-label">AUTHOR</h2>
      <AuthorCard variant="full" />
    </section>

    <!-- ブログコンセプト -->
    <section class="about-section">
      <h2 class="section-label">CONCEPT</h2>
      <div class="concept-block">
        <h3 class="concept-title">「モテる」とは、人に愛される男になること。</h3>
        <p class="concept-text">
          このブログは、自己磨き・恋愛・健康・投資という4つの軸で、男性が本質的に魅力的になるための知識と実践法を発信しています。
        </p>
        <p class="concept-text">
          表面的なテクニックではなく、内面から変わるための本質的なアプローチを大切にしています。
        </p>
      </div>
    </section>

    <!-- テーマ一覧 -->
    <section class="about-section">
      <h2 class="section-label">THEMES</h2>
      <ul class="themes-grid">
        <li class="theme-item">
          <span class="theme-icon">💪</span>
          <h3 class="theme-name">自己磨き</h3>
          <p class="theme-desc">外見・内面・スキルを磨き、より魅力的な自分へ</p>
        </li>
        <li class="theme-item">
          <span class="theme-icon">❤️</span>
          <h3 class="theme-name">恋愛</h3>
          <p class="theme-desc">モテる男の思考法・行動習慣・コミュニケーション術</p>
        </li>
        <li class="theme-item">
          <span class="theme-icon">🏃</span>
          <h3 class="theme-name">健康</h3>
          <p class="theme-desc">筋トレ・食事・睡眠でベストな体と精神を維持する</p>
        </li>
        <li class="theme-item">
          <span class="theme-icon">📈</span>
          <h3 class="theme-name">投資</h3>
          <p class="theme-desc">お金の不安をなくし、自由な選択肢を手に入れる</p>
        </li>
      </ul>
    </section>

  </div>

</BaseLayout>

<style>
  .about-page {
    max-width: 800px;
    margin: 0 auto;
  }

  .about-header {
    margin-bottom: 4rem;
  }

  .about-eyebrow {
    font-size: 0.7rem;
    letter-spacing: 0.25em;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }

  .about-title {
    font-family: 'Cormorant Garamond', var(--font-serif);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 300;
    color: var(--color-text);
    line-height: 1.2;
    margin-bottom: 1.5rem;
  }

  .about-line {
    width: 60px;
    height: 2px;
    background: var(--color-accent);
  }

  .about-section {
    margin-bottom: 4rem;
  }

  .section-label {
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--color-border);
  }

  .concept-block {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    padding: 2rem 2.5rem;
    border-left: 3px solid var(--color-accent);
  }

  .concept-title {
    font-family: 'Cormorant Garamond', var(--font-serif);
    font-size: 1.4rem;
    font-weight: 400;
    color: var(--color-text);
    margin-bottom: 1.25rem;
    line-height: 1.5;
  }

  .concept-text {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.9;
    margin-bottom: 0.75rem;
  }

  .concept-text:last-child {
    margin-bottom: 0;
  }

  .themes-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2px;
  }

  .theme-item {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    padding: 1.75rem;
  }

  .theme-icon {
    font-size: 1.5rem;
    display: block;
    margin-bottom: 0.75rem;
  }

  .theme-name {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }

  .theme-desc {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  @media (max-width: 600px) {
    .themes-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
