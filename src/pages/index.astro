---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

function formatDate(date: Date): string {
  return date.toLocaleDateString('ja-JP', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
  }).replace(/\//g, '.');
}

const latestPost = posts[0];
---

<BaseLayout title="モテる男の教科書" fullWidth={true}>

  <!-- ヒーローセクション -->
  <section class="hero">
    <div class="hero-bg">
      <img
        src="https://images.unsplash.com/photo-1576091160550-2173dba999ef?w=1600&q=80"
        alt="hero"
        class="hero-img"
      />
    </div>
    <div class="hero-overlay"></div>

    <!-- 赤い丸アクセント -->
    <div class="hero-circle"></div>

    <!-- ヒーローテキスト -->
    <div class="hero-content">
      <p class="hero-eyebrow">Self Improvement &amp; Dating</p>
      <h1 class="hero-title">
        モテる男の<br />
        <em>教科書</em>
      </h1>
    </div>

    <!-- 最新記事ティッカー -->
    {latestPost && (
      <div class="hero-ticker">
        <span class="ticker-date">{formatDate(latestPost.data.pubDate)}</span>
        <a href={`/blog/${latestPost.id}/`} class="ticker-title">
          {latestPost.data.title}
        </a>
      </div>
    )}

    <!-- スクロールインジケーター -->
    <div class="hero-scroll">
      <span>Scroll</span>
      <span class="scroll-arrow">↓</span>
    </div>
  </section>

  <!-- 記事グリッド -->
  <section class="articles-section">
    <div class="articles-header">
      <h2 class="articles-label">LATEST ARTICLES</h2>
      <div class="articles-line"></div>
    </div>

    <ul class="articles-grid">
      {posts.map((post, i) => (
        <li class={`article-card ${i === 0 ? 'article-card--featured' : ''}`}>
          <a href={`/blog/${post.id}/`} class="article-link">
            {post.data.image && (
              <div class="article-img-wrap">
                <img src={post.data.image} alt={post.data.title} class="article-img" />
                <div class="article-img-overlay"></div>
              </div>
            )}
            <div class="article-body">
              <div class="article-meta">
                <time>{formatDate(post.data.pubDate)}</time>
                {post.data.tags && post.data.tags[0] && (
                  <span class="article-tag">{post.data.tags[0]}</span>
                )}
              </div>
              <h3 class="article-title">{post.data.title}</h3>
              <p class="article-desc">{post.data.description}</p>
              <span class="article-more">Read more →</span>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </section>

</BaseLayout>

<style>
  /* ===== HERO ===== */
  .hero {
    position: relative;
    width: 100%;
    height: 100vh;
    min-height: 600px;
    overflow: hidden;
    display: flex;
    align-items: center;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(0,0,0,0.75) 0%,
      rgba(0,0,0,0.4) 60%,
      rgba(0,0,0,0.2) 100%
    );
  }

  /* 赤い丸 */
  .hero-circle {
    position: absolute;
    left: -120px;
    top: 50%;
    transform: translateY(-50%);
    width: 400px;
    height: 400px;
    border-radius: 50%;
    background: rgba(200, 57, 43, 0.55);
    filter: blur(0px);
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    padding: 0 8%;
    margin-top: 72px;
  }

  .hero-eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    color: rgba(255,255,255,0.6);
    margin-bottom: 1.5rem;
    text-transform: uppercase;
  }

  .hero-title {
    font-family: 'Cormorant Garamond', var(--font-serif);
    font-size: clamp(4rem, 10vw, 9rem);
    font-weight: 300;
    line-height: 1.0;
    color: #fff;
    letter-spacing: -0.02em;
  }

  .hero-title em {
    font-style: italic;
    color: rgba(255,255,255,0.75);
  }

  /* ティッカー */
  .hero-ticker {
    position: absolute;
    bottom: 3rem;
    left: 8%;
    z-index: 2;
    background: rgba(255,255,255,0.95);
    color: #0a0a0a;
    padding: 1rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 1.25rem;
    max-width: 480px;
  }

  .ticker-date {
    font-size: 0.7rem;
    color: #666;
    white-space: nowrap;
    letter-spacing: 0.05em;
  }

  .ticker-title {
    font-size: 0.85rem;
    color: #0a0a0a;
    font-weight: 500;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    transition: color 0.2s;
  }

  .ticker-title:hover {
    color: var(--color-accent);
  }

  /* スクロール */
  .hero-scroll {
    position: absolute;
    bottom: 3rem;
    right: 5%;
    z-index: 2;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: rgba(255,255,255,0.6);
    font-size: 0.7rem;
    letter-spacing: 0.15em;
  }

  .scroll-arrow {
    animation: bounce 1.5s infinite;
  }

  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(4px); }
  }

  /* ===== ARTICLES ===== */
  .articles-section {
    max-width: 1300px;
    margin: 0 auto;
    padding: 6rem 2.5rem 8rem;
  }

  .articles-header {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .articles-label {
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  .articles-line {
    flex: 1;
    height: 1px;
    background: var(--color-border);
  }

  .articles-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
  }

  .article-card--featured {
    grid-column: span 2;
  }

  .article-link {
    display: block;
    color: inherit;
    background: var(--color-surface);
    height: 100%;
    overflow: hidden;
  }

  .article-img-wrap {
    position: relative;
    aspect-ratio: 16/9;
    overflow: hidden;
  }

  .article-card--featured .article-img-wrap {
    aspect-ratio: 16/8;
  }

  .article-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .article-img-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.15);
    transition: background 0.3s;
  }

  .article-link:hover .article-img {
    transform: scale(1.04);
  }

  .article-link:hover .article-img-overlay {
    background: rgba(0,0,0,0.05);
  }

  .article-body {
    padding: 1.5rem;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }

  .article-meta time {
    font-size: 0.7rem;
    color: var(--color-text-muted);
    letter-spacing: 0.05em;
  }

  .article-tag {
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    border: 1px solid var(--color-accent);
    padding: 0.15rem 0.5rem;
  }

  .article-title {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    font-weight: 400;
    line-height: 1.5;
    color: var(--color-text);
    margin-bottom: 0.6rem;
    transition: color 0.2s;
  }

  .article-card--featured .article-title {
    font-size: 1.5rem;
  }

  .article-link:hover .article-title {
    color: rgba(240, 236, 228, 0.7);
  }

  .article-desc {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .article-more {
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    transition: color 0.2s;
  }

  .article-link:hover .article-more {
    color: var(--color-accent);
  }

  @media (max-width: 900px) {
    .articles-grid {
      grid-template-columns: 1fr;
    }
    .article-card--featured {
      grid-column: span 1;
    }
    .hero-circle {
      width: 250px;
      height: 250px;
      left: -80px;
    }
  }
</style>
